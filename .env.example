# Database
DATABASE_URL=postgresql://musiclens:musiclens_pass@localhost:5432/musiclens_db

# Auth
SECRET_KEY=your-super-secret-key-change-in-production-minimum-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# File Storage
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50

# S3 (optional — leave empty to use local storage)
USE_S3=false
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET_NAME=
AWS_REGION=us-east-1

# Frontend
REACT_APP_API_URL=http://localhost:8000
